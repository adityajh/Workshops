# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# In Vercel: add this as an Environment Variable in your project settings.
# ─────────────────────────────────────────────────────────────────────────────

# Your n8n webhook URL (from the Webhook trigger node in your n8n workflow)
# Example: https://your-n8n-instance.app.n8n.cloud/webhook/abc123
N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/your-webhook-id
